{
    "name": "me-shaon/laravel-resilience",
    "description": "Laravel-native fault injection and resilience verification toolkit.",
    "keywords": [
        "laravel",
        "resilience",
        "fault-injection",
        "reliability"
    ],
    "homepage": "https://github.com/me-shaon/laravel-resilience",
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmed Shamim",
            "email": "shaon.cse81@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.0||^8.0",
        "larastan/larastan": "^2.0||^3.0",
        "orchestra/testbench": "^8.0.0||^9.0.0||^10.0.0||^11.0.0",
        "pestphp/pest": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0||^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.0||^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "MeShaon\\LaravelResilience\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MeShaon\\LaravelResilience\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --debug --no-progress --memory-limit=512M",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MeShaon\\LaravelResilience\\LaravelResilienceServiceProvider"
            ],
            "aliases": {
                "Resilience": "MeShaon\\LaravelResilience\\Facades\\Resilience"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
